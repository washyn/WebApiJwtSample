@page
@model WebAppChecker.Pages.IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>

    <a href="/health-ui">Health UI</a>

    <ul>
        <li>Asembly version: @Model.Info.Version</li>
        <li>Build time: @Model.Info.BuildTime</li>
        <li>Environment: @Model.Info.Environment</li>
        <li>App name: @Model.Info.ImplementationTitle</li>
    </ul>
</div>