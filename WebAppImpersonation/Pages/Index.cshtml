@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
    var users = Model.Users;
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>


<div class="card">
    <div class="card-body">
        <table class="table table-sm table-bordered">
            <thead>
                <tr>
                    <th>#</th>
                    <th>User Name</th>
                    <th>Email</th>
                    <th>Options</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.UserName</td>
                        <td>@user.Email</td>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <td>
                                @if (User.FindFirstValue(ClaimTypes.NameIdentifier) != user.Id && !User.HasClaim(c => c.Type == CustomClaimTypes.ImpersonatorUserId))
                                {
                                    <a asp-page="/Impersonate" asp-route-userId="@user.Id" class="btn btn-outline-primary btn-sm">Impersonate</a>
                                }
                                else if (User.FindFirstValue(ClaimTypes.NameIdentifier) == user.Id)
                                {
                                    <span class="badge bg-secondary text-dark">Current User</span>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>