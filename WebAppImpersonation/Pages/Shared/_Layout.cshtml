<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebAppImpersonation</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebAppImpersonation.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        @if (User.Identity?.IsAuthenticated == true && User.HasClaim(c => c.Type == WebAppImpersonation.Pages.CustomClaimTypes.ImpersonatorUserId))
        {
            <div class="alert alert-warning mb-0 text-center rounded-0">
                <div class="container d-flex justify-content-between align-items-center">
                    <span>
                        <strong>Modo Impersonación:</strong> Estás actuando como <strong>@User.Identity.Name</strong>. 
                        (Original: @User.FindFirst(WebAppImpersonation.Pages.CustomClaimTypes.ImpersonatorUserName)?.Value)
                    </span>
                    <form asp-page="/Impersonate" asp-page-handler="StopImpersonation" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Detener Impersonación</button>
                    </form>
                </div>
            </div>
        }
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">WebAppImpersonation</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WebAppImpersonation - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>